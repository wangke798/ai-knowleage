# 开发环境本地配置模板。复制为 application-dev.yml 后填入真实 key / 密码。
# application-dev.yml 已被 .gitignore，请勿入库。
spring:
  datasource:
    dynamic:
      primary: master
      strict: false
      datasource:
        master:
          url: jdbc:mysql://localhost:3306/ai_kb?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
          username: ${DB_USERNAME:root}
          password: ${DB_PASSWORD:root}
          driver-class-name: com.mysql.cj.jdbc.Driver
        pgvector:
          # PgVector 容器：docker run -d --name pgvector -e POSTGRES_PASSWORD=postgres \
          #   -e POSTGRES_DB=ai_kb_vector -p 5432:5432 pgvector/pgvector:pg16
          url: jdbc:postgresql://localhost:5432/ai_kb_vector
          username: ${PG_USERNAME:postgres}
          password: ${PG_PASSWORD:postgres}
          driver-class-name: org.postgresql.Driver

  data:
    redis:
      host: ${REDIS_HOST:localhost}
      port: ${REDIS_PORT:6379}
      password: ${REDIS_PASSWORD:}
      database: 0

  flyway:
    enabled: true
    locations: classpath:db/migration
    baseline-on-migrate: true
    encoding: UTF-8

  # Spring AI：通义百炼通过 OpenAI 兼容协议接入
  # 申请地址：https://bailian.console.aliyun.com/
  ai:
    openai:
      api-key: ${DASHSCOPE_API_KEY:sk-your-dashscope-key}
      base-url: ${DASHSCOPE_BASE_URL:https://dashscope.aliyuncs.com/compatible-mode}
      chat:
        options:
          model: qwen-plus
          temperature: 0.7
      embedding:
        options:
          model: text-embedding-v3

    # 可选：Ollama 本地（保留以便调试）
    ollama:
      base-url: ${OLLAMA_BASE_URL:http://localhost:11434}
      chat:
        options:
          model: qwen2.5:7b
      embedding:
        options:
          model: bge-m3

    # PgVector 向量库
    vectorstore:
      pgvector:
        index-type: HNSW
        distance-type: COSINE_DISTANCE
        dimensions: 1024    # text-embedding-v3 / bge-m3 都是 1024 维
        initialize-schema: true
